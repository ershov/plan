{
  "description": "Load plan ticket status at session start",
  "hooks": {
    "SessionStart": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "bash ${CLAUDE_PLUGIN_ROOT}/hooks/scripts/load-plan-context.sh",
            "timeout": 10
          }
        ]
      }
    ]
  }
}
