def _status_bar_message(msg):
    """Show an action prompt on the info separator — bold yellow on blue, rest separator."""
    layout = layout_panes()
    row = layout['info_row']
    cols = layout['cols']
    if row <= 0:
        return
    S = '\u2500'
    move(row, 1)
    clear_line()
    set_style(fg=11, bg=4, bold=True)
